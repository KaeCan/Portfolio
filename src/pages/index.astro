---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Hero } from '@/features/hero';

const siteEntry = await getEntry('site', 'site');
if (!siteEntry) {
    throw new Error('Missing site content entry');
}

const { name, role, description } = siteEntry.data;
---

<BaseLayout
    title={`${name} - ${role}`}
    description={description}
    currentPath="/"
>
    <Hero name={name} role={role} />
</BaseLayout>

<script>
    import { isMacPlatform } from '@/utils/platform';

    const modKey = document.querySelector('[data-mod-key]');
    if (modKey && isMacPlatform(navigator.userAgent)) {
        modKey.textContent = '⌘';
    }
</script>
