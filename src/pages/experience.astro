---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Experience } from '@/features/experience';
import { getSortedExperiences } from '@/features/experience/utils/get-sorted-experiences';

const siteEntry = await getEntry('site', 'site');
if (!siteEntry) {
    throw new Error('Missing site content entry');
}

const experiences = await getSortedExperiences();
const { name, description, stats } = siteEntry.data;
---

<BaseLayout
    title={`Experience - ${name}`}
    description={description}
    currentPath="/experience"
>
    <Experience experiences={experiences} stats={stats} client:visible />
</BaseLayout>
