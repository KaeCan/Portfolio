---
interface Props {
    name: string;
    role: string;
}

const { name, role } = Astro.props;
---

<section class="hero">
    <div class="hero__container">
        <div class="hero__avatar-wrap">
            <div class="hero__avatar-ring">
                <div class="hero__avatar">
                    <svg
                        width="64"
                        height="64"
                        fill="#9ca3af"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
            </div>
        </div>

        <h1 class="hero__heading">
            Hi, I'm{' '}
            <span class="hero__name">{name}</span>
        </h1>

        <p class="hero__subtitle">{role}</p>

        <div class="hero__hint-wrap">
            <div class="hero__hint glass">
                <span class="hero__kbds">
                    <kbd class="kbd" data-mod-key>Ctrl</kbd>
                    <kbd class="kbd">K</kbd>
                </span>
                <span>or tap the menu button to navigate</span>
            </div>
        </div>
    </div>
</section>

<script>
    const modKey = document.querySelector('[data-mod-key]');
    if (modKey && navigator.userAgent.toLowerCase().includes('mac')) {
        modKey.textContent = '⌘';
    }
</script>

<style>
    .hero {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .hero__container {
        max-width: var(--page-max);
        margin: 0 auto;
        padding: 0 1rem;
        text-align: center;
    }

    .hero__avatar-wrap {
        margin-bottom: 2rem;
        opacity: 0;
        transform: translateY(-30px);
        animation: fade-up 0.8s ease forwards;
    }

    .hero__avatar-ring {
        width: 8rem;
        height: 8rem;
        margin: 0 auto;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #9333ea);
        padding: 4px;
        box-shadow:
            0 20px 40px rgba(0, 0, 0, 0.12),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .hero__avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background-color: #374151;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero__heading {
        font-size: clamp(3rem, 8vw, 4.5rem);
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateX(-40px);
        animation: fade-right 0.8s ease 0.1s forwards;
    }

    .hero__name {
        background: linear-gradient(135deg, #2563eb, #9333ea);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .hero__subtitle {
        font-size: clamp(1.25rem, 3vw, 1.5rem);
        color: #cbd5e1;
        margin-bottom: 2rem;
        line-height: 1.6;
        opacity: 0;
        transform: translateX(40px);
        animation: fade-left 0.8s ease 0.3s forwards;
    }

    .hero__hint-wrap {
        margin-bottom: 3rem;
        opacity: 0;
        transform: translateY(30px);
        animation: fade-up 0.8s ease 0.5s forwards;
    }

    .hero__hint {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1.5rem;
        color: rgba(255, 255, 255, 0.9);
        border-radius: 9999px;
        font-size: 0.875rem;
    }

    .hero__kbds {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    @keyframes fade-up {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fade-right {
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes fade-left {
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>
