---
interface Project {
    id: string;
    title: string;
    description: string;
    technologies: string[];
    githubUrl?: string;
    liveUrl?: string;
    imageUrl?: string;
}

interface Props {
    projects: Project[];
    githubProfile: string;
}

const { projects, githubProfile } = Astro.props;
---

<section class="projects">
    <div class="projects__container">
        <div class="projects__grid">
            {
                projects.map(project => {
                    const isSingleButton = Boolean(
                        (project.liveUrl && !project.githubUrl) ||
                            (!project.liveUrl && project.githubUrl)
                    );

                    return (
                        <article class="projects__card glass">
                            <div class="projects__image">
                                {project.imageUrl ? (
                                    <img
                                        src={project.imageUrl}
                                        alt={project.title}
                                        loading="lazy"
                                    />
                                ) : (
                                    <span
                                        class="projects__placeholder"
                                        aria-hidden="true"
                                    >
                                        ◆
                                    </span>
                                )}
                            </div>
                            <div class="projects__content">
                                <h2 class="projects__title">{project.title}</h2>
                                <p class="projects__description">
                                    {project.description}
                                </p>
                                <div class="projects__tech">
                                    {project.technologies.map(tech => (
                                        <span class="tech-chip">{tech}</span>
                                    ))}
                                </div>
                            </div>
                            <div class="projects__actions">
                                {project.liveUrl && (
                                    <a
                                        href={project.liveUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class:list={[
                                            'projects__btn',
                                            'projects__btn--primary',
                                            {
                                                'projects__btn--full':
                                                    isSingleButton,
                                            },
                                        ]}
                                    >
                                        <svg
                                            viewBox="0 0 24 24"
                                            width="18"
                                            height="18"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path d="M3.9 12a5 5 0 0 1 0-7.07l.7-.7a5 5 0 0 1 7.08 0L13 5.58a1 1 0 0 1-1.41 1.41L10.24 5.7a3 3 0 0 0-4.24 0l-.7.7a3 3 0 0 0 0 4.24l1.41 1.42a1 1 0 1 1-1.41 1.41L3.9 12zm16.2 0a5 5 0 0 1 0 7.07l-.7.7a5 5 0 0 1-7.08 0L11 18.42a1 1 0 0 1 1.41-1.41l1.35 1.29a3 3 0 0 0 4.24 0l.7-.7a3 3 0 0 0 0-4.24l-1.41-1.42a1 1 0 1 1 1.41-1.41L20.1 12zM8.46 14.12a1 1 0 0 1 0-1.41l5.66-5.66a1 1 0 1 1 1.41 1.41l-5.66 5.66a1 1 0 0 1-1.41 0z" />
                                        </svg>
                                        Live Demo
                                    </a>
                                )}
                                {project.githubUrl && (
                                    <a
                                        href={project.githubUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class:list={[
                                            'projects__btn',
                                            'projects__btn--secondary',
                                            {
                                                'projects__btn--full':
                                                    isSingleButton,
                                            },
                                        ]}
                                    >
                                        <svg
                                            viewBox="0 0 24 24"
                                            width="18"
                                            height="18"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.8-1.3-1.8-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.6 1.2 3.2.9.1-.7.4-1.2.7-1.5-2.7-.3-5.5-1.3-5.5-6a4.6 4.6 0 0 1 1.2-3.2c-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.4 3.6 18.4 4 18.4 4c.6 1.6.2 2.8.1 3.1a4.6 4.6 0 0 1 1.2 3.2c0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z" />
                                        </svg>
                                        View Code
                                    </a>
                                )}
                            </div>
                        </article>
                    );
                })
            }
        </div>

        <div class="projects__github">
            <a
                href={githubProfile}
                target="_blank"
                rel="noopener noreferrer"
                class="projects__github-btn glass"
            >
                <svg
                    viewBox="0 0 24 24"
                    width="20"
                    height="20"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.8-1.3-1.8-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.6 1.2 3.2.9.1-.7.4-1.2.7-1.5-2.7-.3-5.5-1.3-5.5-6a4.6 4.6 0 0 1 1.2-3.2c-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.4 3.6 18.4 4 18.4 4c.6 1.6.2 2.8.1 3.1a4.6 4.6 0 0 1 1.2 3.2c0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"
                    ></path>
                </svg>
                <span>View All Projects on GitHub</span>
            </a>
        </div>
    </div>
</section>

<style>
    .projects {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        overflow-y: auto;
        padding: 2rem 0 4rem;
    }

    @media (min-width: 768px) {
        .projects {
            padding: 3rem 0 4rem;
        }
    }

    .projects__container {
        max-width: var(--page-max-wide);
        margin: 0 auto;
        padding: 0 1rem;
        width: 100%;
    }

    .projects__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .projects__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .projects__card {
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 300ms ease-out;
    }

    .projects__card:hover {
        transform: translateY(-0.75rem);
        background-color: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.25);
    }

    .projects__image {
        height: 12rem;
        background-color: #374151;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .projects__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
    }

    .projects__placeholder {
        color: #94a3b8;
        font-size: 3rem;
    }

    .projects__content {
        padding: 1.5rem;
        flex-grow: 1;
    }

    .projects__title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 0.75rem;
    }

    .projects__description {
        color: #cbd5e1;
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .projects__tech {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .projects__actions {
        padding: 0 1.5rem 1.5rem;
        display: flex;
        gap: 1rem;
    }

    .projects__btn {
        flex: 1;
        text-align: center;
        padding: 0.75rem 1rem;
        font-weight: 500;
        border-radius: 0.5rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition:
            background-color 250ms ease-out,
            transform 250ms ease-out;
    }

    .projects__btn--primary {
        background-color: rgba(37, 99, 235, 0.3);
        color: #f1f5f9;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .projects__btn--primary:hover {
        background-color: rgba(37, 99, 235, 0.4);
        transform: translateY(-2px);
    }

    .projects__btn--secondary {
        background-color: rgba(255, 255, 255, 0.08);
        color: #f1f5f9;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .projects__btn--secondary:hover {
        background-color: rgba(255, 255, 255, 0.12);
        transform: translateY(-2px);
    }

    .projects__github {
        text-align: center;
        margin-top: 3rem;
    }

    .projects__github-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        border-radius: 0.75rem;
        transition: transform 300ms ease-out;
    }

    .projects__github-btn:hover {
        transform: translateY(-0.5rem);
        background-color: rgba(255, 255, 255, 0.12);
    }
</style>
