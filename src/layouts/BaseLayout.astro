---
import { getEntry } from 'astro:content';
import '@pigment-css/react/styles.css';
import SEO from '@/components/seo/SEO.astro';
import { CommandPalette } from '@/features/command-palette';
import {
    buildPaletteCommands,
    normalizePath,
} from '@/features/command-palette/utils/palette-commands';
import '@/styles/global.css';

export interface Props {
    title?: string;
    description?: string;
    currentPath?: string;
}

const siteEntry = await getEntry('site', 'site');
if (!siteEntry) {
    throw new Error('Missing site content entry');
}

const site = siteEntry.data;
const {
    title = `${site.name} - ${site.role}`,
    description = site.description,
    currentPath = Astro.url.pathname.replace(/\/$/, '') || '/',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const paletteCommands = buildPaletteCommands(site, base);
const normalizedPath = normalizePath(currentPath, base);
---

<!doctype html>
<html lang="en">
    <head>
        <SEO title={title} description={description} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            (function () {
                try {
                    var theme = localStorage.getItem('portfolio-theme');
                    if (theme && theme !== 'mocha') {
                        document.documentElement.dataset.theme = theme;
                    }
                } catch (e) {}
            })();
        </script>
    </head>
    <body>
        <div class="app-shell">
            <main class="page-enter">
                <slot />
            </main>
        </div>
        <CommandPalette
            client:load
            commands={paletteCommands}
            currentPath={normalizedPath}
        />
    </body>
</html>
