---
import { getEntry } from 'astro:content';
import SEO from '../components/seo/SEO.astro';
import CommandPalette from '../components/islands/CommandPalette';
import '../styles/global.css';

export interface Props {
    title?: string;
    description?: string;
    currentPath?: string;
}

const siteEntry = await getEntry('site', 'site');
if (!siteEntry) {
    throw new Error('Missing site content entry');
}

const site = siteEntry.data;
const {
    title = `${site.name} - ${site.role}`,
    description = site.description,
    currentPath = Astro.url.pathname.replace(/\/$/, '') || '/',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const withBase = (href: string): string => {
    if (href.startsWith('http') || href.startsWith('mailto:')) return href;
    if (href === '/') return `${base}/` || '/';
    return `${base}${href}`;
};

const paletteCommands = {
    navigation: site.navigation.map(item => ({
        id: item.id,
        label: item.label,
        currentLabel: item.currentLabel,
        href: withBase(item.href),
        icon: item.icon,
        path: item.href === '/' ? '/' : item.href,
    })),
    social: site.social.map(item => ({
        id: item.id,
        label: item.label,
        href: withBase(item.href),
        icon: item.icon,
        external: item.external,
    })),
    actions: site.actions.map(item => ({
        id: item.id,
        label: item.label,
        href: withBase(item.href),
        icon: item.icon,
        external: item.external,
    })),
};

const normalizedPath = (() => {
    const withoutBase = currentPath.startsWith(base)
        ? currentPath.slice(base.length) || '/'
        : currentPath;
    return withoutBase === '' ? '/' : withoutBase;
})();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <SEO title={title} description={description} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            document.documentElement.classList.add('dark');
        </script>
    </head>
    <body>
        <div class="app-shell">
            <main class="page-enter">
                <slot />
            </main>
            <CommandPalette
                client:idle
                commands={paletteCommands}
                currentPath={normalizedPath}
            />
        </div>
    </body>
</html>
